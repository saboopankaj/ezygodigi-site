<style>
/* --- BASE MARQUEE STRUCTURE (Required for it to work) --- */
.marquee-container {
    width: 100%;
    overflow: hidden; /* Hides the scrollbar */
    user-select: none;
    border-bottom: 1px solid #e2e8f0;
}

.marquee-content {
    display: flex; /* Lines up items in a row */
    width: max-content; /* Allows row to be longer than the screen */
    will-change: transform;
}

/* --- LOCATION MARQUEE CUSTOMIZATION --- */
.location-marquee {
    background: #f8fafc; 
    padding: 12px 0;
}

.location-marquee .m-item {
    color: #764ba2; 
    font-weight: 600;
    text-transform: none; 
    font-size: 14px;
    padding: 0 40px; 
    white-space: nowrap; /* Prevents text from breaking into 2 lines */
    display: flex;
    align-items: center;
}

/* --- REVERSE ANIMATION --- */
/* Reduced from 50s to 35s for faster speed */
.reverse-scroll {
    animation: scrollLoopReverse 35s linear infinite !important;
}

@keyframes scrollLoopReverse {
    0% { transform: translateX(-50%); }
    100% { transform: translateX(0); }
}

.marquee-content:hover {
    animation-play-state: paused;
}

/* --- MOBILE OPTIMIZATION --- */
@media (max-width: 768px) {
    .reverse-scroll {
        animation-duration: 20s !important; /* Faster on mobile */
    }
    .location-marquee .m-item {
        font-size: 12px;
        padding: 0 20px;
    }
}
</style>


