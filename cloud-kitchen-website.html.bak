<style>
/* --- CLOUD KITCHEN SECTION --- */
.ck-section {
    padding: 120px 0;
    background: #0f172a; /* Professional Deep Navy */
    color: #ffffff;
    font-family: 'Poppins', sans-serif;
}

.ck-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
}

.pill-row { display: flex; gap: 10px; margin-bottom: 25px; }
.pill-badge { padding: 6px 14px; border-radius: 100px; font-size: 11px; font-weight: 800; text-transform: uppercase; }
.pill-badge.orange { background: #f97316; color: white; }
.pill-badge.white { background: rgba(255,255,255,0.1); color: white; border: 1px solid rgba(255,255,255,0.2); }

.ck-content h2 { font-size: 42px; font-weight: 800; line-height: 1.2; margin-bottom: 20px; }
.ck-content h2 span { color: #f97316; }

.ck-lead { font-size: 18px; color: #94a3b8; margin-bottom: 40px; line-height: 1.7; }

/* Feature Items */
.ck-feature-grid { display: grid; gap: 30px; margin-bottom: 40px; }
.ck-f-item { display: flex; gap: 20px; }
.ck-f-icon { width: 50px; height: 50px; background: rgba(249, 115, 22, 0.1); border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 24px; flex-shrink: 0; }
.ck-f-text h4 { font-size: 18px; font-weight: 700; margin-bottom: 5px; color: #f8fafc; }
.ck-f-text p { font-size: 14px; color: #64748b; }

.ck-cta { color: #f97316; font-weight: 700; text-decoration: none; border-bottom: 2px solid transparent; transition: 0.3s; }
.ck-cta:hover { border-bottom-color: #f97316; }

/* Profit Visual Card */
.profit-calculator-card {
    background: #1e293b;
    padding: 40px;
    border-radius: 32px;
    border: 1px solid rgba(255,255,255,0.05);
    position: relative;
}

.profit-calculator-card h4 { text-align: center; margin-bottom: 30px; font-size: 22px; }
.calc-row { display: flex; justify-content: space-between; padding: 15px 0; border-bottom: 1px solid rgba(255,255,255,0.05); }
.red-text { color: #ef4444; font-weight: 800; }
.green-text { color: #22c55e; font-weight: 800; }
.calc-divider { text-align: center; margin: 15px 0; font-weight: 900; color: #475569; }
.calc-note { font-size: 11px; color: #475569; margin-top: 15px; text-align: center; }

.whatsapp-alert-mini {
    position: absolute;
    bottom: -20px;
    right: -20px;
    background: #25d366;
    color: white;
    padding: 12px 20px;
    border-radius: 15px;
    font-size: 12px;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 10px;
    box-shadow: 0 20px 40px rgba(37, 211, 102, 0.3);
}

@media (max-width: 992px) {
    .ck-grid { grid-template-columns: 1fr; gap: 50px; text-align: center; }
    .pill-row { justify-content: center; }
    .ck-f-item { flex-direction: column; align-items: center; }
    .whatsapp-alert-mini { right: 50%; transform: translateX(50%); }
}
</style>

