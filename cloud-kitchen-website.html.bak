<style>
/* --- HYBRID FOOD HERO --- */
.hero-hybrid-food {
    padding: 100px 0;
    background: #ffffff;
    font-family: 'Poppins', sans-serif;
    overflow: hidden;
}

.hero-flex-wrapper {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 60px;
}

.hero-main-content { flex: 1.2; }

/* Badge Pills */
.pill-row { display: flex; gap: 12px; margin-bottom: 25px; }
.pill-badge {
    padding: 6px 14px;
    border-radius: 100px;
    font-size: 12px;
    font-weight: 800;
    text-transform: uppercase;
}
.pill-badge.status { background: #f0fdf4; color: #16a34a; }
.pill-badge.feature { background: #eff6ff; color: #2563eb; }

.hero-main-content h1 {
    font-size: clamp(34px, 5vw, 50px);
    font-weight: 900;
    color: #0f172a;
    line-height: 1.15;
    margin-bottom: 20px;
}

.hero-main-content h1 span { color: #4f46e5; }

.hero-lead {
    font-size: 18px;
    color: #475569;
    line-height: 1.6;
    margin-bottom: 30px;
    max-width: 580px;
}

/* Feature Checklist */
.feature-check-list {
    list-style: none;
    padding: 0;
    margin-bottom: 40px;
}
.feature-check-list li {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 16px;
    font-weight: 600;
    color: #1e293b;
    margin-bottom: 12px;
}

/* Big CTA Button */
.btn-commerce-lg {
    display: inline-flex;
    align-items: center;
    gap: 15px;
    background: #0f172a;
    color: white;
    padding: 20px 40px;
    border-radius: 20px;
    text-decoration: none;
    font-weight: 800;
    font-size: 18px;
    box-shadow: 0 20px 40px rgba(15, 23, 42, 0.2);
    transition: 0.3s;
}

.btn-commerce-lg:hover {
    background: #25d366; /* Changes to WhatsApp green on hover */
    transform: translateY(-5px);
}

.cta-hint { font-size: 13px; color: #94a3b8; margin-top: 12px; font-weight: 500; }

/* Visual Side: Floating Order Card */
.hero-system-preview {
    flex: 0.8;
    position: relative;
    display: flex;
    justify-content: center;
}

.order-card-float {
    background: white;
    border: 1px solid #e2e8f0;
    padding: 25px;
    border-radius: 24px;
    box-shadow: 0 40px 80px rgba(0,0,0,0.1);
    width: 300px;
    z-index: 2;
    animation: float 4s ease-in-out infinite;
}

@keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-15px); }
}

.order-header { display: flex; justify-content: space-between; border-bottom: 1px solid #f1f5f9; padding-bottom: 12px; margin-bottom: 15px; }
.order-header strong { color: #10b981; font-size: 14px; }
.order-time { font-size: 11px; color: #94a3b8; }

.order-details p { font-size: 14px; margin: 4px 0; color: #1e293b; font-weight: 600; }

.order-footer { display: flex; justify-content: space-between; margin-top: 15px; padding-top: 12px; border-top: 1px dashed #e2e8f0; }
.order-total { font-weight: 800; font-size: 15px; }
.payment-status { color: #2563eb; font-size: 12px; font-weight: 700; }

/* Tablet/Mobile Layout */
@media (max-width: 992px) {
    .hero-flex-wrapper { flex-direction: column; text-align: center; }
    .pill-row, .feature-check-list li { justify-content: center; }
    .hero-system-preview { display: none; }
    .hero-main-content { display: flex; flex-direction: column; align-items: center; }
}
</style>

