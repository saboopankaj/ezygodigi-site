<style>

/* --- LIVE HOOK STRIP STYLES --- */
.live-hook-strip {
    padding: 60px 0;
    background: #f8fafc;
    border-bottom: 1px solid #e2e8f0;
}

.hook-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: 60px;
    align-items: center;
}

/* Browser Mockup Style */
.live-browser-mockup {
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0,0,0,0.08);
    border: 1px solid #e2e8f0;
}

.browser-header {
    background: #f1f5f9;
    padding: 10px 15px;
    display: flex;
    align-items: center;
    gap: 6px;
}

.browser-header .dot {
    width: 8px;
    height: 8px;
    background: #cbd5e1;
    border-radius: 50%;
}

.browser-url {
    margin-left: 15px;
    background: #fff;
    font-size: 11px;
    color: #64748b;
    padding: 3px 15px;
    border-radius: 4px;
    flex-grow: 1;
    text-align: center;
    font-weight: 600;
}

.live-browser-mockup img {
    width: 100%;
    display: block;
    height: 250px;
    object-fit: cover;
    object-position: top;
}

/* Hook Content */
.live-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #ecfdf5;
    color: #059669;
    padding: 6px 14px;
    border-radius: 50px;
    font-size: 12px;
    font-weight: 700;
    margin-bottom: 20px;
}

.ping {
    width: 8px;
    height: 8px;
    background: #10b981;
    border-radius: 50%;
    position: relative;
}

.ping::after {
    content: '';
    position: absolute;
    width: 100%;
    height: 100%;
    background: inherit;
    border-radius: inherit;
    animation: ping-anim 1.5s infinite;
}

.hook-content h3 { font-size: 32px; font-weight: 900; color: #0f172a; margin-bottom: 15px; }
.hook-content h3 span { color: #4f46e5; }
.hook-content p { color: #64748b; font-size: 16px; line-height: 1.6; margin-bottom: 25px; }

/* Actions */
.hook-actions { display: flex; align-items: center; gap: 20px; }
.btn-live {
    background: #0f172a;
    color: #fff;
    padding: 12px 24px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 700;
    font-size: 14px;
    transition: 0.3s;
}

.btn-link {
    color: #4f46e5;
    text-decoration: none;
    font-weight: 700;
    font-size: 14px;
    border-bottom: 2px solid transparent;
}

.btn-live:hover { background: #4f46e5; transform: translateY(-2px); }
.btn-link:hover { border-bottom-color: #4f46e5; }

/* Responsive */
@media (max-width: 900px) {
    .hook-grid { grid-template-columns: 1fr; text-align: center; gap: 40px; }
    .hook-actions { justify-content: center; }
    .live-browser-mockup { max-width: 400px; margin: 0 auto; }
}

@keyframes ping-anim {
    0% { transform: scale(1); opacity: 1; }
    100% { transform: scale(3); opacity: 0; }
}

</style>

