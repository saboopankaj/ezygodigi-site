    -webkit-text-fill-color: transparent;
}

.cta-content p {
    font-size: 19px;
    color: #94a3b8;
    max-width: 700px;
    margin: 0 auto 45px;
    line-height: 1.6;
}

/* Action Buttons */
.cta-actions {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 25px;
    margin-bottom: 45px;
}

.btn-cta-main {
    background: #4f46e5;
    color: #ffffff;
    padding: 20px 45px;
    border-radius: 18px;
    font-weight: 800;
    font-size: 18px;
    text-decoration: none;
    transition: all 0.3s ease;
    box-shadow: 0 15px 30px rgba(79, 70, 229, 0.3);
}

.btn-cta-main:hover {
    background: #4338ca;
    transform: translateY(-5px);
    box-shadow: 0 20px 40px rgba(79, 70, 229, 0.5);
}

.btn-cta-link {
    color: #ffffff;
    font-weight: 700;
    text-decoration: none;
    font-size: 16px;
    border-bottom: 2px solid rgba(255,255,255,0.1);
    padding-bottom: 5px;
    transition: 0.3s;
}

.btn-cta-link:hover {
    border-bottom-color: #4f46e5;
    color: #818cf8;
}

/* Trust Elements */
.cta-trust-footer {
    display: flex;
    justify-content: center;
    gap: 30px;
    border-top: 1px solid rgba(255,255,255,0.05);
    padding-top: 35px;
}

.cta-trust-footer span {
    color: #475569;
    font-size: 14px;
    font-weight: 600;
}

/* Mobile Adjustments */
@media (max-width: 768px) {
    .cta-actions { flex-direction: column; gap: 15px; }
    .cta-glass-card { padding: 60px 20px; }
    .cta-trust-footer { flex-direction: column; gap: 10px; }
}

</style>

