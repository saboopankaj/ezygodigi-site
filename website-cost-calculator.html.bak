<style>
/* --- PREMIUM HERO STYLING --- */
.ezy-premium-hero {
    position: relative;
    min-height: calc(100vh - 80px);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 80px 20px;
    background: #0f172a;
    font-family: 'Poppins', sans-serif !important;
}

/* 1. BACKGROUND IMAGE & OVERLAY */
.hero-bg-media {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    background-image: url('/assets/images/hero/ad-landing-seo.webp');
    background-size: cover;
    background-position: center;
    opacity: 0.25; /* Adjusted for readability */
    z-index: 1;
}

.hero-overlay-deep {
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    background: linear-gradient(to bottom, rgba(15, 23, 42, 0.95), rgba(15, 23, 42, 0.75));
    z-index: 2;
}

.hero-content-stack { position: relative; z-index: 10; width: 100%; max-width: 800px; }

/* 2. BADGES & TEXT */
.status-badge-row { display: flex; justify-content: center; gap: 10px; margin-bottom: 20px; }
.badge-yellow {
    background: #fbbf24 !important;
    color: #0f172a !important;
    padding: 6px 14px;
    border-radius: 50px;
    font-size: 0.7rem;
    font-weight: 800;
    text-transform: uppercase;
}
.badge-glass {
    background: rgba(255, 255, 255, 0.1);
    color: #fff;
    padding: 6px 14px;
    border-radius: 50px;
    font-size: 0.7rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
}

.hero-title {
    font-size: clamp(26px, 6vw, 42px);
    font-weight: 800;
    color: #fff;
    line-height: 1.15;
    margin-bottom: 20px !important;
}

.hero-subtitle {
    font-size: clamp(14px, 4vw, 16px);
    color: #94a3b8;
    line-height: 1.6;
    margin-bottom: 30px !important;
}

/* 3. USP PILLS */
.hero-usp-row {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 15px;
    margin-bottom: 40px !important;
}

.usp-item {
    color: #e2e8f0;
    font-size: 0.8rem;
    background: rgba(255, 255, 255, 0.05);
    padding: 8px 16px;
    border-radius: 100px;
    display: flex;
    align-items: center;
    gap: 8px;
    border: 1px solid rgba(255, 255, 255, 0.05);
}
.usp-item i { color: #4f46e5; }

/* 4. ANIMATED CTA & WHATSAPP */
.hero-main-btn {
    background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
    color: white !important;
    text-decoration: none;
    padding: 18px 45px;
    border-radius: 100px;
    font-weight: 700;
    font-size: 1.1rem;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    box-shadow: 0 15px 30px rgba(79, 70, 229, 0.4);
    animation: cta-bounce 2s infinite ease-in-out;
}

@keyframes cta-bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
}

.whatsapp-helper {
    margin-top: 25px;
    font-size: 0.9rem;
    color: #94a3b8;
}

.whatsapp-helper a {
    color: #25d366; /* WhatsApp Green */
    text-decoration: none;
    font-weight: 700;
    margin-left: 5px;
    display: inline-flex;
    align-items: center;
    gap: 5px;
}

.whatsapp-helper a:hover {
    text-decoration: underline;
}

/* Mobile Fixes */
@media (max-width: 768px) {
    .ezy-premium-hero { padding-top: 100px !important; min-height: auto; }
    .hero-usp-row { flex-direction: column; align-items: center; gap: 10px; }
}
