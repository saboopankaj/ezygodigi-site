    }

    .s-container {
        max-width: 1100px;
        margin: 0 auto;
        padding: 0 20px;
    }

    /* 2. HEADERS & BADGES */
    .s-header {
        text-align: center;
        margin-bottom: 50px;
        max-width: 800px;
        margin-left: auto;
        margin-right: auto;
    }

    .s-badge {
        display: inline-block;
        background: var(--primary-gradient);
        color: var(--white);
        padding: 6px 16px;
        border-radius: 50px;
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        margin-bottom: 15px;
        letter-spacing: 1px;
    }

    .s-header h2 {
        font-family: 'Poppins', sans-serif !important;
        font-size: clamp(26px, 5vw, 36px);
        font-weight: 800;
        color: var(--dark-navy);
        margin-bottom: 15px;
        line-height: 1.2;
    }

    .s-header p {
        font-size: 16px;
        color: var(--text-muted);
        line-height: 1.6;
    }

    /* 3. GRID & CARD STYLING */
    .s-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 30px;
        margin-bottom: 60px;
    }

    .s-card {
        background: var(--white);
        padding: 35px;
        border-radius: var(--radius-lg);
        border: 1px solid rgba(0,0,0,0.05);
        box-shadow: 0 10px 40px rgba(0,0,0,0.04);
        transition: transform 0.3s ease;
        font-family: 'Poppins', sans-serif !important;
    }

    .s-card:hover {
        transform: translateY(-5px);
    }

    .s-card.highlight {
        border: 2px solid var(--primary-color);
        background: #f8faff;
    }

    .s-icon {
        font-size: 36px;
        margin-bottom: 20px;
        display: block;
    }

    .s-card h3, .s-card h4 {
        font-family: 'Poppins', sans-serif !important;
        font-size: 22px;
        font-weight: 700;
        color: var(--dark-navy);
        margin-bottom: 12px;
    }

    .s-list {
        list-style: none;
        padding: 0;
    }

    .s-list li {
        font-size: 14px;
        color: var(--text-muted);
        margin-bottom: 10px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .s-list span {
        color: var(--primary-color);
        font-weight: bold;
    }

    /* 4. PRICING TIER SPECIALS */
    .tier-card {
        text-align: center;
    }

    .s-price-range {
        font-family: 'Poppins', sans-serif !important;
        font-size: 24px;
        font-weight: 800;
        color: var(--primary-color);
        margin-bottom: 15px;
        display: block;
    }

    /* 5. FOOTER NOTE */
    .s-footer-note {
        text-align: center;
        padding: 40px 20px;
        border-top: 1px solid #eef2f6;
        color: var(--text-muted);
        font-size: 15px;
        line-height: 1.6;
    }

    .s-footer-note strong {
        color: var(--dark-navy);
        font-weight: 700;
    }

    /* RESPONSIVE SYNC */
    @media (max-width: 768px) {
        .seo-explainer-v1 { padding: 50px 0; }
        .s-grid { grid-template-columns: 1fr; gap: 20px; }
        .s-card { padding: 25px; }
    }
</style>


