            width: 100%; /* Full width button on mobile */
            padding: 16px 20px;
            font-size: 16px;
        }
    }
</style>

<script>
    const RATES = {
        base: { 'landing': 2999, 'business': 29999, 'ecommerce': 49999 },
        addons: { 
            'cms_basic': 7500, 'cms_adv': 15000, 
            'seo': 5000, 'ga_gsc': 2000,
            'whatsapp': 1000, 'sms': 1000, 'email': 1000, 'pg': 7500,
            'logo': 500, 'graphics': 4500
        }
    };
    let currentStep = 0;
    let calcData = { biz: '', cat: '', type: '', items: [] };

    function renderStep() {
        const container = document.getElementById('stepContent');
        const dots = document.querySelectorAll('.dot');
        dots.forEach((d, i) => d.className = i <= currentStep ? 'dot active' : 'dot');
        document.getElementById('prevBtn').style.visibility = currentStep === 0 ? 'hidden' : 'visible';
        document.getElementById('btnText').innerText = currentStep === 6 ? 'Get Free Consultation' : 'Continue';

        let html = '';
        if (currentStep === 0) {
            html = `<div class="step-ui"><h2>Brand Details</h2><p>Let's personalize your quote</p>
                <input type="text" class="calc-input" id="bn" placeholder="Business Name" value="${calcData.biz}" oninput="calcData.biz=this.value">
                <select class="calc-input" onchange="calcData.cat=this.value">
                    <option value="">Select Industry...</option>
                    <option value="Food" ${calcData.cat==='Food'?'selected':''}>Food & Catering</option>
                    <option value="Retail" ${calcData.cat==='Retail'?'selected':''}>E-commerce/Retail</option>
                    <option value="Edu" ${calcData.cat==='Edu'?'selected':''}>Education/LMS</option>
                    <option value="Other" ${calcData.cat==='Other'?'selected':''}>Corporate/Services</option>
                </select></div>`;
        } else if (currentStep === 1) {
            html = `<div class="step-ui"><h2>Core Framework</h2><div class="list-options">
                <div class="opt-item ${calcData.type==='landing'?'selected':''}" onclick="calcData.type='landing';renderStep()"><i class="fas fa-bolt"></i><div class="opt-info"><b>Landing Page</b><span>Lead focused (1 Page)</span></div></div>
                <div class="opt-item ${calcData.type==='business'?'selected':''}" onclick="calcData.type='business';renderStep()"><i class="fas fa-building"></i><div class="opt-info"><b>Business Pro</b><span>Company Profile (5-8 Pages)</span></div></div>
                <div class="opt-item ${calcData.type==='ecommerce'?'selected':''}" onclick="calcData.type='ecommerce';renderStep()"><i class="fas fa-shopping-cart"></i><div class="opt-info"><b>E-Commerce</b><span>Online Store with Checkout</span></div></div>
            </div></div>`;
        } else if (currentStep === 2) {
            html = `<div class="step-ui"><h2>CMS Management</h2><div class="list-options">
                <div class="opt-item ${calcData.items.includes('cms_basic')?'selected':''}" onclick="toggleCMS('cms_basic')"><i class="fas fa-edit"></i><div class="opt-info"><b>Basic CMS</b><span>Edit text & images easily</span></div></div>
                <div class="opt-item ${calcData.items.includes('cms_adv')?'selected':''}" onclick="toggleCMS('cms_adv')"><i class="fas fa-database"></i><div class="opt-info"><b>Advanced Admin</b><span>Manage users, orders & data</span></div></div>
            </div></div>`;
        } else if (currentStep === 3) {
            html = `<div class="step-ui"><h2>Interactions</h2><div class="list-options">
                <div class="opt-item ${calcData.items.includes('whatsapp')?'selected':''}" onclick="toggle('whatsapp')"><i class="fab fa-whatsapp"></i><div class="opt-info"><b>WhatsApp Orders</b></div></div>
                <div class="opt-item ${calcData.items.includes('pg')?'selected':''}" onclick="toggle('pg')"><i class="fas fa-credit-card"></i><div class="opt-info"><b>Payment Gateway</b></div></div>
                <div class="opt-item ${calcData.items.includes('sms')?'selected':''}" onclick="toggle('sms')"><i class="fas fa-comment-alt"></i><div class="opt-info"><b>SMS Alerts / OTP</b></div></div>
                <div class="opt-item ${calcData.items.includes('email')?'selected':''}" onclick="toggle('email')"><i class="fas fa-envelope-open-text"></i><div class="opt-info"><b>Auto-Emails</b></div></div>
            </div></div>`;
        } else if (currentStep === 4) {
            html = `<div class="step-ui"><h2>SEO & Analytics</h2><div class="list-options">
                <div class="opt-item ${calcData.items.includes('seo')?'selected':''}" onclick="toggle('seo')"><i class="fas fa-search-dollar"></i><div class="opt-info"><b>Pro SEO Package</b></div></div>
                <div class="opt-item ${calcData.items.includes('ga_gsc')?'selected':''}" onclick="toggle('ga_gsc')"><i class="fas fa-chart-line"></i><div class="opt-info"><b>Google Analytics & Search Console</b></div></div>
            </div></div>`;
        } else if (currentStep === 5) {
            html = `<div class="step-ui"><h2>Branding</h2><div class="list-options">
                <div class="opt-item ${calcData.items.includes('logo')?'selected':''}" onclick="toggle('logo')"><i class="fas fa-pen-nib"></i><div class="opt-info"><b>Custom Logo Design</b></div></div>
                <div class="opt-item ${calcData.items.includes('graphics')?'selected':''}" onclick="toggle('graphics')"><i class="fas fa-palette"></i><div class="opt-info"><b>Creative Graphics</b></div></div>
            </div></div>`;
        } else if (currentStep === 6) {
            html = `<div class="step-ui"><h2>Contact Info</h2><p>Send details for your free proposal.</p>
                <input type="text" class="calc-input" id="uN" placeholder="Full Name">
                <input type="tel" class="calc-input" id="uP" placeholder="WhatsApp Number"></div>`;
        }
        container.innerHTML = html;
        updatePrice();
    }

    function toggle(v) {
        const i = calcData.items.indexOf(v);
        if (i > -1) calcData.items.splice(i, 1); else calcData.items.push(v);
        renderStep();
    }

    function toggleCMS(v) {
        calcData.items = calcData.items.filter(item => item !== 'cms_basic' && item !== 'cms_adv');
        calcData.items.push(v);
        renderStep();
    }

    function updatePrice() {
        if(!calcData.type) { document.getElementById('totalPrice').innerText = '₹ 0'; return; }
        let total = RATES.base[calcData.type] || 0;
        calcData.items.forEach(a => total += (RATES.addons[a] || 0));
        document.getElementById('totalPrice').innerText = '₹' + total.toLocaleString('en-IN');
    }

    function changeStep(dir) {
        if (dir === 1) {
            if (currentStep === 0 && (!calcData.biz || !calcData.cat)) return alert("Please fill Brand details");
            if (currentStep === 1 && !calcData.type) return alert("Select a Core Framework");
            if (currentStep === 6) return submitQuote();
        }
        currentStep += dir; renderStep();
        document.getElementById('quote-calculator').scrollIntoView({ behavior: 'smooth' });
    }

    async function submitQuote() {
        const name = document.getElementById('uN').value;
        const phone = document.getElementById('uP').value;
        if (!name || !phone) return alert("Contact details required");
        document.getElementById('btnText').innerText = "Sending...";
        try {
            await fetch('https://dev.ezygodigi.in/api/contact', { 
                method: 'POST', 
                headers: { 'Content-Type': 'application/json' }, 
                body: JSON.stringify({ 
                    name, phone, email: 'hello@ezygodigi.in', 
                    business: calcData.biz, 
                    budget: document.getElementById('totalPrice').innerText, 
                    message: `V5 Calc | Type: ${calcData.type} | Tools: ${calcData.items.join(',')}` 
                }) 
            });
            document.getElementById('successPopup').style.display = 'flex';
        } catch (e) {
            document.getElementById('successPopup').style.display = 'flex';
        }
    }
    renderStep();
</script>

