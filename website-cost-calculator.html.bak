<style>
    /* 1. CTA SECTION BASE */
    .seo-cta {
        padding: 80px 0;
        background: var(--white);
        /* Force EzyGoDigi Branding */
        font-family: 'Poppins', sans-serif !important;
        text-align: center;
    }

    .s-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 0 20px;
    }

    /* 2. TYPOGRAPHY SYNC */
    .seo-cta h2 {
        font-family: 'Poppins', sans-serif !important;
        font-size: clamp(26px, 5vw, 36px);
        font-weight: 800;
        color: var(--dark-navy);
        margin-bottom: 20px;
        line-height: 1.2;
    }

    .seo-cta p {
        font-family: 'Poppins', sans-serif !important;
        font-size: 16px;
        color: var(--text-muted);
        margin-bottom: 35px;
        line-height: 1.6;
    }

    /* 3. BUTTON STYLING (Matches Calculator "Continue" Button) */
    .seo-cta .btn-continue {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: var(--primary-gradient);
        color: var(--white) !important;
