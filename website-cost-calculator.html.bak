        padding: 18px 40px;
        border-radius: var(--radius-md);
        font-weight: 700;
        font-size: 18px;
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);
        border: none;
        font-family: 'Poppins', sans-serif !important;
